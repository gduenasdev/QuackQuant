# Copy this file to `.env` in the repository root on the Mac Studio before running Compose.
# Keep the real `.env` out of git.

# Public HTTP port for the website/API gateway.
QUACKQUANT_HTTP_PORT=8080

# Optional hostname or LAN address other devices will use to reach the Mac Studio.
# Examples: macstudio.local, 192.168.1.50
MAC_STUDIO_HOSTNAME=macstudio.local

# Change this before using anything beyond local development.
POSTGRES_PASSWORD=change_me_to_a_long_random_value

# Optional host ports if the defaults conflict with local services.
POSTGRES_PORT=5432
REDIS_PORT=6379

# Native model server running on the Mac Studio host, outside Docker.
# Keep model serving separate from the app stack so Apple Silicon inference can use the best runtime.
QUACKQUANT_MODEL_SERVER_BASE_URL=http://host.docker.internal:8002
